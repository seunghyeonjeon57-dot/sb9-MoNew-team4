{
	"info": {
		"_postman_id": "mon-124-interest-automation",
		"name": "MoNew Interest API (self-contained)",
		"description": "관심사(Interest) 도메인 자동화 테스트. MON-112 Swagger 계약 + MON-122 예외 번역 기준.\n\n실행 순서 의존성이 있으므로 Collection Runner로 순차 실행 필수.\n\n환경 변수:\n- baseUrl: http://localhost:8080 (로컬)\n- runSuffix: 매 run 마다 현재 timestamp 자동 세팅 (이메일·이름 중복 회피)\n- userId: 00b login 응답에서 자동 세팅\n- interestId: 01 등록 응답에서 자동 세팅",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [],
	"variable": [
		{"key": "baseUrl", "value": "http://localhost:8080"},
		{"key": "userId", "value": ""},
		{"key": "interestId", "value": ""},
		{"key": "runSuffix", "value": ""}
	],
	"item": [
		{
			"name": "00a. POST /api/users — 테스트 유저 등록 (setup)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.collectionVariables.set('runSuffix', String(Date.now()));"
						]
					}
				},
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('201 Created', () => pm.response.to.have.status(201));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"newman+{{runSuffix}}@monew.test\",\n  \"nickname\": \"newman{{runSuffix}}\",\n  \"password\": \"Newman1234!\"\n}"
				},
				"url": {"raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"]}
			}
		},
		{
			"name": "00b. POST /api/users/login — 로그인 후 userId 저장 (setup)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('200 OK', () => pm.response.to.have.status(200));",
							"const body = pm.response.json();",
							"pm.test('UserDto.id 존재', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
							"pm.collectionVariables.set('userId', body.id);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"newman+{{runSuffix}}@monew.test\",\n  \"password\": \"Newman1234!\"\n}"
				},
				"url": {"raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api", "users", "login"]}
			}
		},
		{
			"name": "01. POST /api/interests — 등록 (201)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('201 Created', () => pm.response.to.have.status(201));",
							"const body = pm.response.json();",
							"pm.test('응답 바디에 id 포함', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
							"pm.test('응답 name 일치', () => pm.expect(body.name).to.eql(pm.collectionVariables.get('runSuffix') ? '경제_' + pm.collectionVariables.get('runSuffix') : body.name));",
							"pm.test('keywords 배열 유지', () => pm.expect(body.keywords).to.have.lengthOf(3));",
							"pm.test('초기 subscriberCount 0', () => pm.expect(body.subscriberCount).to.eql(0));",
							"pm.test('subscribedByMe false', () => pm.expect(body.subscribedByMe).to.eql(false));",
							"pm.collectionVariables.set('interestId', body.id);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{"key": "Content-Type", "value": "application/json"},
					{"key": "Monew-Request-User-ID", "value": "{{userId}}"}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"경제_{{runSuffix}}\",\n  \"keywords\": [\"주식\", \"금리\", \"환율\"]\n}"
				},
				"url": {"raw": "{{baseUrl}}/api/interests", "host": ["{{baseUrl}}"], "path": ["api", "interests"]}
			}
		},
		{
			"name": "02. POST 정확 일치 중복 → 409 (잔여2)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('409 Conflict', () => pm.response.to.have.status(409));",
							"pm.test('code: SIMILAR_INTEREST_NAME', () => pm.expect(pm.response.json().code).to.eql('SIMILAR_INTEREST_NAME'));",
							"pm.test('similarity=1.0', () => pm.expect(pm.response.json().details.similarity).to.eql(1.0));"
						]
					}
				}
			],
			"request": {
				"method": "POST",
