		{
			"name": "07. GET 목록 조회 (필수 파라미터 전부) → 200",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('200 OK', () => pm.response.to.have.status(200));",
							"const body = pm.response.json();",
							"pm.test('content 배열 존재', () => pm.expect(body.content).to.be.an('array'));",
							"pm.test('size 필드 존재', () => pm.expect(body.size).to.be.a('number'));",
							"pm.test('hasNext 필드 존재', () => pm.expect(body.hasNext).to.be.a('boolean'));",
							"pm.test('nextAfter 필드 존재 (Swagger 준수)', () => pm.expect(body).to.have.property('nextAfter'));",
							"const myInterest = body.content.find(i => i.id === pm.collectionVariables.get('interestId'));",
							"pm.test('방금 등록한 관심사 포함', () => pm.expect(myInterest).to.exist);",
							"pm.test('subscribedByMe=false (아직 미구독)', () => pm.expect(myInterest.subscribedByMe).to.eql(false));"
						]
					}
				}
			],
