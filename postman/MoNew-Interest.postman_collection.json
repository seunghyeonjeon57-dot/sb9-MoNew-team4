						"exec": [
							"pm.test('200 OK (Swagger)', () => pm.response.to.have.status(200));",
							"const body = pm.response.json();",
							"pm.test('id 포함', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
							"pm.test('interestId 일치', () => pm.expect(body.interestId).to.eql(pm.collectionVariables.get('interestId')));",
